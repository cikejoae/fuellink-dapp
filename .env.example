# ─── Wallet / Deployer ────────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix required by Hardhat)
PRIVATE_KEY=your_deployer_private_key

# ─── Alchemy ──────────────────────────────────────────────────────────────────
# Alchemy API key — used for Hardhat deploy RPC and frontend provider.
# Create a project at https://dashboard.alchemy.com (Polygon + Polygon Amoy apps).
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key

# ─── WalletConnect ────────────────────────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id

# ─── PolygonScan verification ─────────────────────────────────────────────────
# Used by `npx hardhat verify`. Get key at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_key

# ─── Contract Addresses (populated after `npm run deploy:amoy` or `deploy:polygon`) ──
NEXT_PUBLIC_FUEL_TOKEN_ADDRESS=
NEXT_PUBLIC_FUELX_TOKEN_ADDRESS=
NEXT_PUBLIC_STAKING_ADDRESS=
NEXT_PUBLIC_DAO_ADDRESS=
NEXT_PUBLIC_TREASURY_ADDRESS=
NEXT_PUBLIC_VESTING_ADDRESS=
NEXT_PUBLIC_STO_ADDRESS=
NEXT_PUBLIC_TIMELOCK_ADDRESS=
NEXT_PUBLIC_USDT_ADDRESS=
