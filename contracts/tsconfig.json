{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop":  true,
    "strict":           true,
    "outDir":           "./dist",
    "resolveJsonModule":true,
    "skipLibCheck":     true
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules"]
}
